# 공공데이터포털(data.go.kr) 발급 인증키
# 실제 값은 .env.local 또는 .env 에 넣으세요 (둘 다 .gitignore 로 커밋 제외되고,
# 앱과 pnpm ingest 양쪽에서 자동 로드됩니다 — .env.local 이 우선).
# 두 변수 모두 필요합니다: 키만 넣으면 ingest 가 엔드포인트 누락으로 멈춥니다.

# 공공데이터포털 마이페이지 > 인증키에서 확인 (Encoding/Decoding 둘 다 올 수 있음)
DATA_GO_KR_SERVICE_KEY=여기에_발급받은_인증키

# 15100066(가공식품 표준데이터) 표준데이터 오픈API 엔드포인트.
# 이 키가 해당 API에 활용신청·승인돼 있어야 pnpm ingest 가 동작합니다.
# 파라미터: serviceKey, pageNo, numOfRows, type=json (응답 response.body.items).
DATA_GO_KR_15100066_ENDPOINT=https://api.data.go.kr/openapi/tn_pubr_public_nutri_process_info_api

# (선택) 수집 페이지 크기(기본 200 — 1000은 응답이 커서 느림)와 샘플 상한.
# INGEST_MAX_PAGES 를 두면 그만큼만 부분 적재(라이브 검증/시연용). 미설정=전체(약 59만 건).
# INGEST_PER_PAGE=200
# INGEST_MAX_PAGES=25
